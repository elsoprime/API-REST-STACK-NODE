NODE_ENV=development
PORT=4000
APP_NAME=SaaS Core Engine
APP_VERSION=3.0.0
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
# development runtime loads .env.dev via npm run dev
# production runtime loads .env via npm run start or an equivalent process manager setup
# development defaults to port 4000 and emits lifecycle logs for startup, DB readiness and shutdown

MONGODB_URI=mongodb://localhost:27017/saas_dev?replicaSet=rs0
MONGODB_URI_TEST=mongodb://localhost:27017/saas_test?replicaSet=rs0
MONGODB_MAX_POOL_SIZE=10
MONGODB_CONNECT_TIMEOUT_MS=10000
DB_CONNECT_MAX_RETRIES=3
DB_CONNECT_RETRY_DELAY_MS=1000

JWT_SECRET=change_this_value_to_at_least_64_characters_long_for_production_use
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
AUTH_ACCESS_COOKIE_NAME=__at
REFRESH_TOKEN_COOKIE_NAME=__rf
PLATFORM_ADMIN_EMAILS=admin@example.com

COOKIE_SECRET=change_this_value_to_at_least_64_characters_long_for_production_use
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

CSRF_SECRET=change_this_value_to_at_least_32_characters
CSRF_COOKIE_NAME=__csrf

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GLOBAL=100
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_SENSITIVE=5
RATE_LIMIT_MAX_REFRESH=20

CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
LOG_PRETTY=true
# Legacy flag kept for backward compatibility. Production readiness now enforces real delivery adapters.
GO_LIVE_ENFORCE_PROD_DELIVERY_ADAPTERS=false
EMAIL_PROVIDER=mailpit
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=SaaS Core Engine
AUTH_VERIFY_EMAIL_URL=http://localhost:5173/auth/verify-email
AUTH_RESET_PASSWORD_URL=http://localhost:5173/auth/reset-password
TENANT_INVITATION_ACCEPT_URL=http://localhost:5173/tenant/invitations/accept
EMAIL_MAILPIT_SMTP_HOST=127.0.0.1
EMAIL_MAILPIT_SMTP_PORT=1025
EMAIL_RESEND_API_KEY=
EMAIL_RESEND_API_BASE_URL=https://api.resend.com
EMAIL_DELIVERY_TIMEOUT_MS=5000
AUTH_TWO_FACTOR_PROVISIONING_WEBHOOK_URL=
DELIVERY_WEBHOOK_AUTH_TOKEN=
DELIVERY_WEBHOOK_TIMEOUT_MS=5000`r`n