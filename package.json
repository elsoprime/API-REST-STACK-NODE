{
  "name": "api-rest-stack-node",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS Core Engine V3 bootstrap",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --env-file=.env.dev --import tsx --watch src/app/index.ts",
    "start": "node --env-file=.env dist/app/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:smoke": "vitest run tests/e2e/go-live/smoke.staging.test.ts tests/integration/health.test.ts tests/integration/go-live/production-readiness-guards.test.ts tests/integration/auth/auth.routes.test.ts tests/integration/tenant/tenant.routes.test.ts tests/integration/tenant/invitations.routes.test.ts tests/integration/tenant-settings/tenant-settings.routes.test.ts tests/integration/inventory/inventory.routes.test.ts tests/integration/inventory/inventory.stock-history.test.ts tests/integration/audit/audit.routes.test.ts tests/integration/tenant/tenant-isolation.test.ts",
    "test:restore": "vitest run tests/e2e/go-live/restore.drill.test.ts tests/integration/go-live/restore.mongodb-drill.test.ts",
    "test:restore:mongodb": "vitest run tests/integration/go-live/restore.mongodb-drill.test.ts",
    "test:restore:mongodb:enabled": "powershell -NoProfile -Command \"$env:ENABLE_MONGODB_RESTORE_DRILL='true'; npm run test:restore:mongodb\"",
    "mailpit:up": "docker compose -f docker/mailpit/docker-compose.yml up -d",
    "mailpit:down": "docker compose -f docker/mailpit/docker-compose.yml down",
    "mongo:restore:up": "docker compose -f docker/mongodb-replicaset/docker-compose.restore.yml up -d",
    "mongo:restore:down": "docker compose -f docker/mongodb-replicaset/docker-compose.restore.yml down",
    "mongo:restore:reset": "docker compose -f docker/mongodb-replicaset/docker-compose.restore.yml down -v",
    "go-live:check": "npm run build && npm run lint && npm run openapi:validate && npm run test:smoke && npm run test:restore",
    "openapi:validate": "swagger-cli validate openapi/openapi.yaml",
    "docs:coupling:check": "powershell -ExecutionPolicy Bypass -File ./scripts/check-docs-coupling.ps1",
    "docs:cierres:validate": "node ./scripts/validate-cierres-nomenclature.mjs"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@eslint/js": "^9.22.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
